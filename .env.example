# Database
DATABASE_URL=
OLD_DATABASE_URL=

# Application
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
ADMIN_FRONTEND_URL=http://localhost:5173

# HTTP server timeouts (milliseconds)
SERVER_TIMEOUT_MS=120000
HEADERS_TIMEOUT_MS=130000
KEEP_ALIVE_TIMEOUT_MS=65000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOWED_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Origin,X-Requested-With,Content-Type,Accept,Authorization,X-API-Key,X-Client-Version,Cache-Control,Pragma
CORS_EXPOSED_HEADERS=X-Total-Count,X-Page-Count,X-Current-Page
CORS_MAX_AGE=86400

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=1m
JWT_REFRESH_EXPIRES=7d
JWT_ISSUER=app.auth
JWT_AUDIENCE_API=app.api
JWT_AUDIENCE_REFRESH=app.refresh

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Email (Resend)
RESEND_API_KEY=
MAIL_FROM_ADDRESS=

# AI providers
OPENAI_API_KEY=
OPENAI_MODEL=
MISTRAL_API_KEY=
MISTRAL_MODEL=

# Internal HTTP client
API_BASE_URL=http://localhost:3001/api
HTTP_TIMEOUT=10000
HTTP_MAX_RETRIES=3
HTTP_RETRY_DELAY=1000
BEARER_TOKEN=

# Supabase
PROJECT_SUPABASE_URL=
API_SUPABASE_KEY=
SUPABASE_BUCKET_NAME=

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_PUBLIC_URL=
MINIO_BUCKET_IMAGES=images
MINIO_BUCKET_VIDEOS=videos
MINIO_BUCKET_AUDIOS=audios
MINIO_BUCKET_DOCUMENTS=documents
MINIO_BUCKET_OTHERS=others
MINIO_BUCKET_SEO_MEDIA=seo-media

# VNPay online-course payment
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:5173/payment/vnpay-return
VNPAY_IPN_URL=https://public-api-domain.com/api/payments/vnpay/ipn
VNPAY_LOCALE=vn
VNPAY_CURR_CODE=VND

# PayOS online-course payment
# The three credentials must belong to the same PayOS payment channel.
CLIENT_ID_PAYOS=
API_KEY_PAYOS=
CHECKSUM_KEY_PAYOS=
PAYOS_API_URL=https://api-merchant.payos.vn
# If these are blank, APP_URL + /student/payos/return and /student/payos/cancel are used.
PAYOS_RETURN_URL=
PAYOS_CANCEL_URL=
# Set true only while PayOS verifies the webhook URL; set false before real payments.
PAYOS_WEBHOOK_CONFIRMATION_ONLY=false

# Zalo OA
ZALO_APP_ID=
ZALO_OA_SECRET_KEY=
ZALO_MENU_COURSES_URL=
ZALO_MENU_SCHEDULE_URL=
ZALO_MENU_SUPPORT_URL=

# Exam import
EXAM_SPLIT_MAX_CONTENT_LENGTH=

# Student point rules
STUDENT_POINT_COMPETITION_SUBMIT_ENABLED=true
STUDENT_POINT_COMPETITION_SUBMIT_RULES=90:1,100:2
STUDENT_POINT_COMPETITION_SUBMIT_SOURCE=COMPETITION_SUBMIT
STUDENT_POINT_COMPETITION_SUBMIT_REFERENCE_TYPE=COMPETITION_SUBMIT
STUDENT_POINT_ATTENDANCE_ENABLED=true
STUDENT_POINT_ATTENDANCE_POINTS=1
STUDENT_POINT_ATTENDANCE_ELIGIBLE_STATUSES=PRESENT,LATE,MAKEUP
STUDENT_POINT_ATTENDANCE_SOURCE=ATTENDANCE
STUDENT_POINT_ATTENDANCE_REFERENCE_TYPE=ATTENDANCE
STUDENT_POINT_LEARNING_ITEM_LEARNED_ENABLED=true
STUDENT_POINT_LEARNING_ITEM_LEARNED_POINTS=1
STUDENT_POINT_LEARNING_ITEM_LEARNED_SOURCE=LEARNING_ITEM_LEARNED
STUDENT_POINT_LEARNING_ITEM_LEARNED_REFERENCE_TYPE=LEARNING_ITEM
STUDENT_POINT_DEFAULT_CAP_PER_ACTION=100
