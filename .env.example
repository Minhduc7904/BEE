STUDENT_POINT_COMPETITION_SUBMIT_RULES=90:1,100:2
STUDENT_POINT_COMPETITION_SUBMIT_SOURCE=COMPETITION_SUBMIT
STUDENT_POINT_COMPETITION_SUBMIT_REFERENCE_TYPE=COMPETITION_SUBMIT
STUDENT_POINT_ATTENDANCE_ENABLED=true
