  // Website/landing page rieng cua giao vien neu co.
  contactWebsite  String? @map("contact_website") @db.VarChar(255)
  // Dia chi lien he hoac dia diem lop hoc neu duoc phep public.
  contactAddress  String? @map("contact_address") @db.VarChar(500)
  // Link dat lich tu van/hoc thu, co the tro toi form ngoai he thong.
  bookingUrl      String? @map("booking_url") @db.VarChar(1000)
  // Nhan nut CTA, vi du: "Dang ky hoc thu", "Lien he tu van".
  ctaLabel        String? @map("cta_label") @db.VarChar(120)
  // URL cua nut CTA chinh tren trang profile.
  ctaUrl          String? @map("cta_url") @db.VarChar(1000)

  // SEO on-page
  // Tu khoa chinh can SEO cho trang giao vien.
  targetKeyword   String? @map("target_keyword") @db.VarChar(255)
  // Danh sach tu khoa phu, bien the va long-tail.
  keywordText     String? @map("keyword_text") @db.Text
  // Title tag rieng cho SEO, co the khac displayName/H1.
  metaTitle       String? @map("meta_title") @db.VarChar(255)
  // Meta description hien thi tren Google.
  metaDescription String? @map("meta_description") @db.VarChar(500)
  // Tieu de khi chia se len Facebook/Zalo/OpenGraph.
  ogTitle         String? @map("og_title") @db.VarChar(255)
  // Mo ta khi chia se len Facebook/Zalo/OpenGraph.
  ogDescription   String? @map("og_description") @db.VarChar(500)
  // Y dinh tim kiem: teacher profile, tutor, online class, exam prep, ...
  searchIntent    String? @map("search_intent") @db.VarChar(100)
  // Diem SEO noi bo de admin/editor danh gia muc do toi uu.
  seoScore        Int?    @map("seo_score") @db.TinyInt

  // Trang thai va thong ke
  // Trang thai hien thi: DRAFT, PRIVATE, PUBLISHED.
  visibility Visibility @default(DRAFT) @map("visibility")
  // Danh dau giao vien noi bat de dua len trang chu/danh sach.
  isFeatured Boolean    @default(false) @map("is_featured")
