  content           String          @map("content") @db.Text // nội dung bài làm
  points            Int?            @map("points") // điểm số bài làm
  gradedAt          DateTime?       @map("graded_at") @db.Timestamp(0) // thời điểm chấm điểm
  graderId          Int?            @map("grader_id") // admin/giáo viên chấm bài
  feedback          String?         @map("feedback") @db.Text // nhận xét của giáo viên
