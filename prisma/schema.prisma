  // Khu vuc day truc tiep hoac khu vuc phuc vu, vi du: "TP.HCM", "Ha Noi", "Toan quoc".
  teachingArea     String? @map("teaching_area") @db.VarChar(255)
  // Noi cong tac hien tai hoac don vi/thuong hieu ca nhan neu muon public.
  workplace        String? @map("workplace") @db.VarChar(255)

  // Thong tin lien lac
  // Email lien he public tren trang profile.
  contactEmail    String? @map("contact_email") @db.VarChar(120)
  // So dien thoai lien he public.
  contactPhone    String? @map("contact_phone") @db.VarChar(20)
