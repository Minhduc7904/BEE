  @@index([year, month], map: "idx_tuition_payments_year_month")
  @@index([status], map: "idx_tuition_payments_status")
  @@map("tuition_payments")
}

// ============================================
// QUESTION AI CHAT - Äoáº¡n chat giá»¯a ngÆ°á»i dÃ¹ng vÃ  AI vá» cÃ¢u há»i
// ============================================

enum QuestionChatRole {
  USER
  AI
}

model QuestionChat {
  chatId     Int      @id @default(autoincrement()) @map("chat_id")
  userId     Int      @map("user_id")
  questionId Int      @map("question_id")
  title      String?  @map("title") @db.VarChar(255) // tiÃªu Ä‘á» tÃ³m táº¯t cuá»™c há»™i thoáº¡i (optional)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  // Relations
  user     User                  @relation(fields: [userId], references: [userId], onDelete: Cascade)
  question Question              @relation(fields: [questionId], references: [questionId], onDelete: Cascade)
  messages QuestionChatMessage[]

  @@index([userId, questionId], map: "idx_question_chats_user_question")
  @@index([userId, createdAt], map: "idx_question_chats_user_created")
  @@index([questionId], map: "idx_question_chats_question")
  @@map("question_chats")
}

model QuestionChatMessage {
  messageId Int              @id @default(autoincrement()) @map("message_id")
  chatId    Int              @map("chat_id")
  role      QuestionChatRole @map("role") // USER hoáº·c AI
  content   String           @map("content") @db.LongText // ná»™i dung tin nháº¯n
  metadata  Json?            @map("metadata") // token usage, model info, etc.
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamp(0)

  // Relations
  chat QuestionChat @relation(fields: [chatId], references: [chatId], onDelete: Cascade)

  @@index([chatId, createdAt], map: "idx_question_chat_messages_chat_created")
  @@map("question_chat_messages")
}

// ============================================
// JOB QUEUE - HÃ ng Ä‘á»£i xá»­ lÃ½ tÃ¡c vá»¥ báº¥t Ä‘á»“ng bá»™
// ============================================

model Job {
  jobId    Int       @id @default(autoincrement()) @map("job_id")
  type     JobType   @map("type") // Loáº¡i job
  status   JobStatus @default(PENDING) @map("status") // Tráº¡ng thÃ¡i job
  priority Int       @default(0) @map("priority") // Äá»™ Æ°u tiÃªn (sá»‘ cÃ ng cao cÃ ng Æ°u tiÃªn)

  // Dá»¯ liá»‡u
  payload Json? @map("payload") // Dá»¯ liá»‡u Ä‘áº§u vÃ o (params, file path, etc)
  result  Json? @map("result") // Káº¿t quáº£ Ä‘áº§u ra

  // ThÃ´ng tin lá»—i
  errorMessage String? @map("error_message") @db.Text
  errorStack   String? @map("error_stack") @db.Text

  // Retry logic
  retryCount Int @default(0) @map("retry_count") // Sá»‘ láº§n Ä‘Ã£ thá»­ láº¡i
  maxRetries Int @default(3) @map("max_retries") // Sá»‘ láº§n thá»­ láº¡i tá»‘i Ä‘a

  // Thá»i gian
  scheduledAt DateTime? @map("scheduled_at") @db.Timestamp(0) // Thá»i gian dá»± kiáº¿n cháº¡y
  startedAt   DateTime? @map("started_at") @db.Timestamp(0) // Thá»i gian báº¯t Ä‘áº§u xá»­ lÃ½
  completedAt DateTime? @map("completed_at") @db.Timestamp(0) // Thá»i gian hoÃ n thÃ nh
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)

  // Metadata
  createdBy Int?  @map("created_by") // User táº¡o job
  metadata  Json? @map("metadata") // ThÃ´ng tin bá»• sung (progress, logs, etc)

  // Relations
  creator User? @relation("JobCreator", fields: [createdBy], references: [userId], onDelete: SetNull)

  // INDEXES
  @@index([status, priority, createdAt], map: "idx_jobs_status_priority_created")
  @@index([type, status], map: "idx_jobs_type_status")
  @@index([createdBy], map: "idx_jobs_created_by")
  @@index([scheduledAt], map: "idx_jobs_scheduled_at")
  @@map("jobs")
}
