  student           Student         @relation(fields: [studentId], references: [studentId], onDelete: Cascade)
  grader            Admin?          @relation(fields: [graderId], references: [adminId], onDelete: SetNull)

  @@unique([homeworkContentId, studentId], map: "unique_homework_submit")
  @@index([studentId], map: "idx_homework_submits_student_id")
  @@map("homework_submits")
}

model DocumentContent {
