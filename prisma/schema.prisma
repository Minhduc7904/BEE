  @@index([visibility, updatedAt, slug], map: "idx_teacher_profiles_sitemap_published")
  @@index([createdBy], map: "idx_teacher_profiles_created_by")
  @@index([updatedBy], map: "idx_teacher_profiles_updated_by")
  @@fulltext([displayName, headline, shortDescription, bio, expertise, teachingSubjects, teachingMethods, targetKeyword, keywordText, metaTitle, metaDescription], map: "ft_teacher_profiles_seo")
  @@map("teacher_profiles")
}

// Bang tag de phan nhom tai lieu theo tu khoa/chu de SEO.
model Tag {
  // Khoa chinh cua tag.
  tagId Int @id @default(autoincrement()) @map("tag_id")

  // Ten tag hien thi, vi du: "Tich phan", "Toan 12", "On thi THPT".
  name        String   @unique @map("name") @db.VarChar(120)
  // Slug duy nhat cho URL hoac filter tag.
  slug        String   @unique @map("slug") @db.VarChar(160)
  // Loai tag de phan nhom theo khoi lop, chuong, loai tai lieu, ...
  type        TagType  @default(KEYWORD) @map("type")
  // Mo ta ngan cua tag de dung tren trang danh sach tag neu can SEO.
  description String?  @map("description") @db.VarChar(500)
  // Bat/tat tag ma khong can xoa lien ket cu.
  isActive    Boolean  @default(true) @map("is_active")
  // Thoi diem tao tag.
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  // Thoi diem cap nhat tag.
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  // Relations
  documents DocumentTag[]

  @@index([isActive], map: "idx_tags_active")
  @@index([type], map: "idx_tags_type")
  @@map("tags")
}

// Bang mapper gan tag vao tai lieu theo quan he many-to-many.
model DocumentTag {
  // ID tai lieu duoc gan tag.
  documentId Int      @map("document_id")
  // ID tag duoc gan vao tai lieu.
  tagId      Int      @map("tag_id")
  // Thu tu uu tien hien thi tag tren trang tai lieu.
  sortOrder  Int      @default(0) @map("sort_order")
  // Thoi diem gan tag vao tai lieu.
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  // Relations
  document Document @relation(fields: [documentId], references: [documentId], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [tagId], onDelete: Cascade)

  @@id([documentId, tagId])
  @@index([tagId], map: "idx_document_tags_tag")
  @@index([documentId, sortOrder], map: "idx_document_tags_document_order")
  @@map("documents_tags")
}

// Bang vi tri media cho SEO.
// Moi slot (vd: home_hero, home_gallery, footer_banner) co the chua nhieu media.
model SeoMediaSlot {
  slotId Int @id @default(autoincrement()) @map("slot_id")

  // Ma ky thuat duy nhat de FE/BE truy cap slot
  code String @unique @map("code") @db.VarChar(100)

  // Ten hien thi trong admin
  name String @map("name") @db.VarChar(255)

  // Slot nay thuoc page nao, vd: home, about, contact
  pageKey String? @map("page_key") @db.VarChar(100)

  // Loai slot, vd: image, banner, gallery, carousel, video
  type String @default("image") @map("type") @db.VarChar(50)

  // Mo ta muc dich su dung slot
  description String? @map("description") @db.Text

  // Bat/tat slot ma khong can xoa du lieu
  isActive Boolean @default(true) @map("is_active")

  // So luong media toi thieu/toi da trong slot
  minItems Int  @default(0) @map("min_items")
  maxItems Int? @map("max_items")

  // Kich thuoc anh khuyen nghi
  recommendedWidth  Int? @map("recommended_width")
  recommendedHeight Int? @map("recommended_height")

  // Config mo rong cho FE/admin
  metadata Json? @map("metadata")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  items SeoMediaItem[] // Danh sach media thuoc slot nay

  @@index([isActive], map: "idx_seo_media_slots_active")
  @@index([pageKey], map: "idx_seo_media_slots_page_key")
  @@index([type], map: "idx_seo_media_slots_type")
  @@map("seo_media_slots")
}

// Bang mapping media cho tung slot SEO.
// Day la quan he 1-n: 1 slot co nhieu item media.
model SeoMediaItem {
  itemId       Int       @id @default(autoincrement()) @map("item_id") // ID dong item
  slotId       Int       @map("slot_id") // FK toi slot SEO
  bucketName   String    @map("bucket_name") @db.VarChar(100) // Bucket luu file (public)
  objectKey    String    @map("object_key") @db.VarChar(500) // Duong dan file trong bucket
  publicUrl    String    @map("public_url") @db.VarChar(1000) // URL cong khai FE truy cap truc tiep
  originalName String    @map("original_name") @db.VarChar(255) // Ten file goc
  mimeType     String    @map("mime_type") @db.VarChar(100) // Mime type file
  mediaType    MediaType @default(IMAGE) @map("media_type") // Loai media: image/video
  fileSize     BigInt    @map("file_size") // Kich thuoc file (bytes)
  width        Int?      @map("width") // Chieu rong (neu la image)
  height       Int?      @map("height") // Chieu cao (neu la image)
  duration     Float?    @map("duration") // Thoi luong tinh bang giay (neu la video)
  sortOrder    Int       @default(0) @map("sort_order") // Thu tu hien thi trong cung 1 slot
  alt          String?   @map("alt") @db.VarChar(255) // Alt text cho image phuc vu SEO/a11y
  linkUrl      String?   @map("link_url") @db.VarChar(1000) // Link dieu huong khi click media (neu co)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp(0) // Thoi diem tao item
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamp(0) // Thoi diem cap nhat item

  slot SeoMediaSlot @relation(fields: [slotId], references: [slotId], onDelete: Cascade) // Item thuoc slot nao

  @@unique([slotId, objectKey], map: "uq_seo_media_items_slot_object")
  @@index([slotId, sortOrder], map: "idx_seo_media_items_slot_order")
  @@index([slotId, mediaType], map: "idx_seo_media_items_slot_media_type")
  @@index([bucketName, objectKey], map: "idx_seo_media_items_location")
  @@map("seo_media_items")
}

model AchievementBoard {
  achievementBoardId Int    @id @default(autoincrement()) @map("achievement_board_id")
  title              String @map("title") @db.VarChar(255)
  slug               String @unique @map("slug") @db.VarChar(255)

  competitionName  String  @map("competition_name") @db.VarChar(255)
  academicYear     String? @map("academic_year") @db.VarChar(50)
  description      String? @map("description") @db.Text
  shortDescription String? @map("short_description") @db.VarChar(500)

  targetKeyword   String? @map("target_keyword") @db.VarChar(255)
  keywordText     String? @map("keyword_text") @db.Text
  metaTitle       String? @map("meta_title") @db.VarChar(255)
  metaDescription String? @map("meta_description") @db.VarChar(500)
  ogTitle         String? @map("og_title") @db.VarChar(255)
  ogDescription   String? @map("og_description") @db.VarChar(500)
  searchIntent    String? @map("search_intent") @db.VarChar(100)
  seoScore        Int?    @map("seo_score")

  visibility Visibility @default(DRAFT) @map("visibility")
  isFeatured Boolean    @default(false) @map("is_featured")
  viewCount  Int        @default(0) @map("view_count")
  sortOrder  Int        @default(0) @map("sort_order")

  createdBy Int? @map("created_by")
  updatedBy Int? @map("updated_by")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  rows AchievementRow[]

  @@index([visibility], map: "idx_achievement_boards_visibility")
  @@index([competitionName], map: "idx_achievement_boards_competition")
  @@index([academicYear], map: "idx_achievement_boards_academic_year")
  @@index([isFeatured, visibility], map: "idx_achievement_boards_featured_visibility")
  @@index([sortOrder], map: "idx_achievement_boards_sort_order")
  @@fulltext([title, competitionName, academicYear, description, shortDescription, targetKeyword, keywordText, metaTitle, metaDescription], map: "ft_achievement_boards_seo")
  @@map("achievement_boards")
}

model AchievementRow {
  achievementRowId   Int @id @default(autoincrement()) @map("achievement_row_id")
  achievementBoardId Int @map("achievement_board_id")

  studentName String   @map("student_name") @db.VarChar(255)
  schoolName  String?  @map("school_name") @db.VarChar(255)
  grade       Int?     @map("grade") @db.TinyInt
  score       Decimal? @map("score") @db.Decimal(10, 2)
  sortOrder   Int      @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  board AchievementBoard @relation(fields: [achievementBoardId], references: [achievementBoardId], onDelete: Cascade)

  @@index([achievementBoardId, sortOrder], map: "idx_achievement_rows_board_order")
  @@index([schoolName], map: "idx_achievement_rows_school")
  @@index([grade], map: "idx_achievement_rows_grade")
  @@map("achievement_rows")
}

// Bai viet tin tuc phuc vu trang SEO.
// Media khong luu truc tiep trong bang nay. Gan qua MediaUsage voi
// entityType = "NEWS_ARTICLE", entityId = newsArticleId va fieldName nhu
// "cover", "thumbnail", "og_image" hoac "content_image".
model NewsArticle {
  newsArticleId Int             @id @default(autoincrement()) @map("news_article_id")
  type          NewsArticleType @default(NEWS) @map("type")

  // Noi dung hien thi va URL SEO.
  title   String  @map("title") @db.VarChar(255)
  slug    String  @unique @map("slug") @db.VarChar(255)
  excerpt String? @map("excerpt") @db.VarChar(500)

  // contentJson la JSON goc cua Tiptap de FE mo lai va chinh sua.
  // contentHtml la HTML da render tu contentJson de SSR/crawler doc duoc.
  // contentText la text thuong da trich xuat, dung cho tim kiem va tinh read time.
  contentJson Json?   @map("content_json")
  contentHtml String? @map("content_html") @db.LongText
  contentText String? @map("content_text") @db.LongText

  authorName  String?   @map("author_name") @db.VarChar(255)
  publishedAt DateTime? @map("published_at") @db.Timestamp(0)

  // SEO on-page va social sharing.
  targetKeyword   String? @map("target_keyword") @db.VarChar(255)
  keywordText     String? @map("keyword_text") @db.Text
  metaTitle       String? @map("meta_title") @db.VarChar(255)
  metaDescription String? @map("meta_description") @db.VarChar(500)
  ogTitle         String? @map("og_title") @db.VarChar(255)
  ogDescription   String? @map("og_description") @db.VarChar(500)
  canonicalUrl    String? @map("canonical_url") @db.VarChar(1000)
  searchIntent    String? @map("search_intent") @db.VarChar(100)
  seoScore        Int?    @map("seo_score") @db.TinyInt
  // JSON-LD da duoc kiem duyet, vi du NewsArticle, BreadcrumbList, FAQPage.
  structuredData  Json?   @map("structured_data")

  visibility  Visibility @default(DRAFT) @map("visibility")
  isFeatured  Boolean    @default(false) @map("is_featured")
  viewCount   Int        @default(0) @map("view_count")
  readingTime Int?       @map("reading_time")
  sortOrder   Int        @default(0) @map("sort_order")

  createdBy Int?     @map("created_by")
  updatedBy Int?     @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  @@index([visibility, publishedAt], map: "idx_news_articles_visibility_published_at")
  @@index([type, visibility, publishedAt], map: "idx_news_articles_type_visibility_published_at")
  @@index([isFeatured, visibility], map: "idx_news_articles_featured_visibility")
  @@index([sortOrder], map: "idx_news_articles_sort_order")
  @@index([createdBy], map: "idx_news_articles_created_by")
  @@index([updatedBy], map: "idx_news_articles_updated_by")
  @@index([visibility, updatedAt, slug], map: "idx_news_articles_sitemap_published")
  @@fulltext([title, excerpt, contentText, authorName, targetKeyword, keywordText, metaTitle, metaDescription], map: "ft_news_articles_seo")
  @@map("news_articles")
}

enum TuitionPaymentStatus {
  UNPAID // ChÆ°a ná»™p
  PAID // ÄÃ£ ná»™p
}

model TuitionPayment {
  paymentId Int @id @default(autoincrement()) @map("payment_id")

  // OPTIONAL FIELDS
  courseId Int? @map("course_id")
  month    Int  @map("month") @db.TinyInt
  year     Int  @map("year") @db.SmallInt

  // REQUIRED
  studentId Int  @map("student_id")
  amount    Int? @map("amount") // sá»‘ tiá»n pháº£i Ä‘Ã³ng (VND), null = chÆ°a xÃ¡c Ä‘á»‹nh, 0 = miá»…n phÃ­

  status TuitionPaymentStatus @default(UNPAID) @map("status")
  paidAt DateTime?            @map("paid_at") @db.Timestamp(0)
  notes  String?              @map("notes") @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  // ðŸ”‘ RELATIONS (OPTIONAL PHáº¢I ÄI KÃˆM)
  course  Course? @relation(fields: [courseId], references: [courseId], onDelete: SetNull)
  student Student @relation(fields: [studentId], references: [studentId], onDelete: Cascade)

  @@unique([studentId, month, year])
  // INDEXES (OK)
  @@index([studentId], map: "idx_tuition_payments_student_id")
