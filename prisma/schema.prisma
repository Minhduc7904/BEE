// ============================================
// MEDIA MANAGEMENT FOR MINIO
// ============================================

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  OTHER
}

enum MediaStatus {
  UPLOADING
  READY
  FAILED
  DELETED
}

enum MediaVisibility {
  PUBLIC // ai cÅ©ng xem Ä‘Æ°á»£c
  PRIVATE // chá»‰ owner / admin
  PROTECTED // cáº§n login / permission
}

model MediaFolder {
  folderId    Int      @id @default(autoincrement()) @map("folder_id")
  name        String   @map("name") @db.VarChar(255)
  slug        String   @map("slug") @db.VarChar(255)
  description String?  @map("description") @db.Text
  parentId    Int?     @map("parent_id")
  createdBy   Int?     @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  parent   MediaFolder?  @relation("FolderHierarchy", fields: [parentId], references: [folderId], onDelete: Cascade)
  children MediaFolder[] @relation("FolderHierarchy")
  media    Media[]

  @@unique([parentId, slug], map: "uq_media_folders_parent_slug")
  @@index([parentId], map: "idx_media_folders_parent")
  @@index([createdBy], map: "idx_media_folders_created_by")
  @@map("media_folders")
}

model Media {
  mediaId      Int         @id @default(autoincrement()) @map("media_id")
  fileName     String      @map("file_name") @db.VarChar(255)
  originalName String      @map("original_name") @db.VarChar(255)
  mimeType     String      @map("mime_type") @db.VarChar(100)
  fileSize     BigInt      @map("file_size") // bytes
  type         MediaType   @map("type")
  status       MediaStatus @default(UPLOADING) @map("status")

  // MinIO specific fields
  bucketName String  @map("bucket_name") @db.VarChar(100)
  objectKey  String  @map("object_key") @db.VarChar(500) // path trong bucket
  publicUrl  String? @map("public_url") @db.VarChar(1000)

  // Metadata
  width    Int? @map("width") // cho image/video
  height   Int? @map("height") // cho image/video
  duration Int? @map("duration") // giÃ¢y, cho video/audio

  // Organization
  folderId    Int?    @map("folder_id")
  parentId    Int?    @map("parent_id") // parent media for hierarchical structure
  description String? @map("description") @db.Text
  alt         String? @map("alt") @db.VarChar(255) // alt text cho image
  rawContent  String? @map("raw_content") @db.LongText // extracted text content from OCR

  uploadedBy Int?     @map("uploaded_by")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  // Relations
  folder   MediaFolder? @relation(fields: [folderId], references: [folderId], onDelete: SetNull)
  parent   Media?       @relation("MediaHierarchy", fields: [parentId], references: [mediaId], onDelete: SetNull)
  children Media[]      @relation("MediaHierarchy")
  uploader User?        @relation("MediaUploader", fields: [uploadedBy], references: [userId], onDelete: SetNull)
  usages   MediaUsage[]

  @@unique([bucketName, objectKey], map: "unique_media_location")
  @@index([type], map: "idx_media_type")
  @@index([status], map: "idx_media_status")
  @@index([folderId], map: "idx_media_folder")
  @@index([parentId], map: "idx_media_parent")
  @@index([uploadedBy], map: "idx_media_uploaded_by")
  @@index([createdAt], map: "idx_media_created_at")
  @@index([mimeType], map: "idx_media_mime_type")
  @@map("media")
}

model MediaUsage {
  usageId    Int             @id @default(autoincrement()) @map("usage_id")
  mediaId    Int             @map("media_id")
  entityType String          @map("entity_type") @db.VarChar(50) // "USER", "COURSE", "QUESTION", "LESSON", "DOCUMENT", etc
  entityId   Int             @map("entity_id")
  fieldName  String?         @map("field_name") @db.VarChar(100) // "avatar", "thumbnail", "banner", "content_image", etc
  usedBy     Int?            @map("used_by") // user nÃ o sá»­ dá»¥ng media nÃ y
  visibility MediaVisibility @default(PRIVATE) @map("visibility") // pháº¡m vi sá»­ dá»¥ng
  createdAt  DateTime        @default(now()) @map("created_at") @db.Timestamp(0)

  // Relations
  media Media @relation(fields: [mediaId], references: [mediaId], onDelete: Cascade)

  @@unique([mediaId, entityType, entityId, fieldName], map: "unique_media_usage")
  @@index([mediaId], map: "idx_media_usages_media")
  @@index([entityType, entityId], map: "idx_media_usages_entity")
  @@index([usedBy], map: "idx_media_usages_used_by")
  @@map("media_usages")
}

// Bang tai lieu phuc vu SEO va thu vien hoc tap.
// File PDF, anh dai dien, anh preview khong luu truc tiep o day.
// Luu qua MediaUsage voi entityType = "DOCUMENT", entityId = documentId,
// fieldName vi du: "file", "thumbnail", "cover", "preview_image".
model Document {
  // Khoa chinh cua tai lieu.
  documentId Int @id @default(autoincrement()) @map("document_id")

  // Noi dung hien thi
  // Tieu de H1 cua trang tai lieu, vi du: "Tai lieu tich phan lop 12".
  title            String  @map("title") @db.VarChar(255)
  // Duong dan SEO duy nhat, vi du: "tai-lieu-tich-phan".
  slug             String  @unique @map("slug") @db.VarChar(255)
  // Mo ta ngan de hien thi trong danh sach tai lieu.
  shortDescription String? @map("short_description") @db.VarChar(500)
  // Noi dung HTML/Markdown hoac phan giai thich bo sung tren landing page tai lieu.
  content          String? @map("content") @db.LongText

  // Ten nguon hoac tac gia goc neu tai lieu duoc tong hop.
  sourceName String? @map("source_name") @db.VarChar(255)
  // URL nguon tham khao neu co.
  sourceUrl  String? @map("source_url") @db.VarChar(1000)

  // SEO on-page
  // Tu khoa chinh can len top, vi du: "tai lieu tich phan".
  targetKeyword   String?    @map("target_keyword") @db.VarChar(255) // vd: "tai lieu tich phan"
  // Danh sach tu khoa phu, bien the va long-tail.
  keywordText     String?    @map("keyword_text") @db.Text // tu khoa phu, bien the, long-tail
  // Title tag rieng cho SEO, co the khac title H1.
  metaTitle       String?    @map("meta_title") @db.VarChar(255)
  // Meta description hien thi tren Google.
  metaDescription String?    @map("meta_description") @db.VarChar(500)
  // Tieu de khi chia se len Facebook/Zalo/OpenGraph.
  ogTitle         String?    @map("og_title") @db.VarChar(255)
  // Mo ta khi chia se len Facebook/Zalo/OpenGraph.
  ogDescription   String?    @map("og_description") @db.VarChar(500)
  // Y dinh tim kiem: informational, practice, download, exam prep, ...
  searchIntent    String?    @map("search_intent") @db.VarChar(100) // informational, practice, download, exam prep
  // Diem SEO noi bo de admin danh gia muc do toi uu.
  seoScore        Int?       @map("seo_score") @db.TinyInt
  // Trang thai va thong ke
  // Trang thai hien thi: DRAFT, PRIVATE, PUBLISHED.
  visibility      Visibility @default(DRAFT) @map("visibility")
  // Danh dau tai lieu noi bat de dua len trang chu/danh sach.
  isFeatured      Boolean    @default(false) @map("is_featured")
  // Tong luot xem trang tai lieu.
  viewCount       Int        @default(0) @map("view_count")
  // Tong luot tai file tai lieu.
  downloadCount   Int        @default(0) @map("download_count")
  // Thoi gian doc uoc tinh tinh bang phut.
  readingTime     Int?       @map("reading_time") // phut

  // User tao tai lieu.
  createdBy Int?     @map("created_by")
  // User cap nhat tai lieu gan nhat.
  updatedBy Int?     @map("updated_by")
  // Thoi diem tao ban ghi.
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  // Thoi diem cap nhat ban ghi.
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  // Relations
  creator User?         @relation("DocumentCreator", fields: [createdBy], references: [userId], onDelete: SetNull)
  updater User?         @relation("DocumentUpdater", fields: [updatedBy], references: [userId], onDelete: SetNull)
  tags    DocumentTag[]

  @@index([visibility], map: "idx_documents_visibility")
  @@index([targetKeyword], map: "idx_documents_target_keyword")
  @@index([isFeatured, visibility], map: "idx_documents_featured_visibility")
  @@index([createdBy], map: "idx_documents_created_by")
  @@index([updatedBy], map: "idx_documents_updated_by")
  @@index([visibility, updatedAt, slug], map: "idx_documents_sitemap_published")
  @@fulltext([title, shortDescription, content, targetKeyword, keywordText, metaTitle, metaDescription], map: "ft_documents_seo")
  @@map("documents")
}

// Bang thong tin giao vien doc lap cho SEO/landing page.
// Avatar/cover luu qua MediaUsage voi entityType = "TEACHER_PROFILE".
