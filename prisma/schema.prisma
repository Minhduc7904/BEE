  isVisible      Boolean   @default(true) @map("is_visible")
  availableFrom  DateTime? @map("available_from") @db.Timestamp(0)
  availableUntil DateTime? @map("available_until") @db.Timestamp(0)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)

  courseClass CourseClass @relation(fields: [classId], references: [classId], onDelete: Cascade)
  lesson      Lesson      @relation(fields: [lessonId], references: [lessonId], onDelete: Cascade)

  @@id([classId, lessonId])
  @@index([lessonId], map: "idx_course_class_lessons_lesson_id")
  @@index([classId, isVisible], map: "idx_course_class_lessons_class_visible")
